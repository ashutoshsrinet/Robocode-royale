package godmode;

import dev.robocode.tankroyale.botapi.*;
import dev.robocode.tankroyale.botapi.events.*;

public class GodModeBot extends Bot {

    private int moveDirection = 1;
    private double enemyEnergy = 100;

    public static void main(String[] args) {
        new GodModeBot().start();
    }

    GodModeBot() {
        super(BotInfo.fromFile("GodModeBot.json"));
    }

    @Override
    public void run() {

        setAdjustGunForBodyTurn(true);
        setAdjustRadarForGunTurn(true);

        while (isRunning()) {

            if (getRadarTurnRemaining() == 0) {
                setTurnRadarRight(360);
            }
        }
    }

    @Override
    public void onScannedBot(ScannedBotEvent e) {

        double myX = getX();
        double myY = getY();

        double enemyX = e.getX();
        double enemyY = e.getY();

        double enemyHeading = e.getDirection();
        double enemySpeed = e.getSpeed();

        double dx = enemyX - myX;
        double dy = enemyY - myY;

        double distance = Math.sqrt(dx * dx + dy * dy);

        detectEnemyFire(e);

        aimPredictively(enemyX, enemyY, enemyHeading, enemySpeed, distance);

        evasiveMovement(enemyX, enemyY, distance);

        radarLock(enemyX, enemyY);
    }

    private void detectEnemyFire(ScannedBotEvent e) {

        double energyDrop = enemyEnergy - e.getEnergy();

        if (energyDrop > 0 && energyDrop <= 3) {
            moveDirection *= -1;
        }

        enemyEnergy = e.getEnergy();
    }

    private void aimPredictively(double enemyX, double enemyY,
                                 double enemyHeading,
                                 double enemySpeed,
                                 double distance) {

        double firePower = Math.min(3, Math.max(1, 600 / distance));
        double bulletSpeed = 20 - firePower * 3;

        double myX = getX();
        double myY = getY();

        double predictedX = enemyX;
        double predictedY = enemyY;

        int time = 0;

        while (++time * bulletSpeed <
                Math.sqrt((predictedX - myX)*(predictedX - myX) +
                          (predictedY - myY)*(predictedY - myY))) {

            predictedX += Math.sin(Math.toRadians(enemyHeading)) * enemySpeed;
            predictedY += Math.cos(Math.toRadians(enemyHeading)) * enemySpeed;
        }

        double aimAngle =
                Math.toDegrees(Math.atan2(predictedX - myX, predictedY - myY));

        setTurnGunRight(normalize(aimAngle - getGunDirection()));

        if (getGunHeat() == 0) {
            fire(firePower);
        }
    }

    private void evasiveMovement(double enemyX, double enemyY, double distance) {

        double myX = getX();
        double myY = getY();

        double angleToEnemy =
                Math.toDegrees(Math.atan2(enemyX - myX, enemyY - myY));

        setTurnRight(normalize(angleToEnemy - getDirection() + 90));

        setForward(150 * moveDirection);

        if (distance < 120) {
            setBack(120);
        }

        if (distance > 500) {
            setForward(120);
        }
    }

    private void radarLock(double enemyX, double enemyY) {

        double myX = getX();
        double myY = getY();

        double radarAngle =
                Math.toDegrees(Math.atan2(enemyX - myX, enemyY - myY));

        setTurnRadarRight(normalize(radarAngle - getRadarDirection()) * 2);
    }

    private double normalize(double angle) {

        while (angle > 180) angle -= 360;
        while (angle < -180) angle += 360;

        return angle;
    }

    @Override
    public void onHitWall(HitWallEvent e) {

        moveDirection *= -1;
        setForward(150 * moveDirection);
    }

    @Override
    public void onHitBot(HitBotEvent e) {

        fire(3);
        moveDirection *= -1;
        setBack(120);
    }
}
