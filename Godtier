package overlord;

import dev.robocode.tankroyale.botapi.*;
import dev.robocode.tankroyale.botapi.events.*;

public class OverlordBot extends Bot {

    private double enemyEnergy = 100;
    private int moveDirection = 1;

    public static void main(String[] args) {
        new OverlordBot().start();
    }

    OverlordBot() {
        super(BotInfo.fromFile("OverlordBot.json"));
    }

    @Override
    public void run() {

        setAdjustGunForBodyTurn(true);
        setAdjustRadarForGunTurn(true);

        while (isRunning()) {

            if (getRadarTurnRemaining() == 0) {
                setTurnRadarRight(360);
            }

            execute();
        }
    }

    @Override
    public void onScannedBot(ScannedBotEvent e) {

        double absoluteBearing = getHeading() + e.getBearing();

        lockRadar(e);

        dodgeBullets(e);

        aimAndFire(e, absoluteBearing);

        controlDistance(e);

        enemyEnergy = e.getEnergy();
    }

    private void aimAndFire(ScannedBotEvent e, double absBearing) {

        double firePower = Math.min(3, Math.max(1.2, 400 / e.getDistance()));

        double bulletSpeed = 20 - firePower * 3;

        double enemyX = e.getX();
        double enemyY = e.getY();

        double enemyHeading = e.getHeading();
        double enemyVelocity = e.getSpeed();

        double predictedX = enemyX;
        double predictedY = enemyY;

        int time = 0;

        while (++time * bulletSpeed <
                distance(getX(), getY(), predictedX, predictedY)) {

            predictedX += Math.sin(Math.toRadians(enemyHeading)) * enemyVelocity;
            predictedY += Math.cos(Math.toRadians(enemyHeading)) * enemyVelocity;
        }

        double aimAngle =
                Math.toDegrees(Math.atan2(predictedX - getX(), predictedY - getY()));

        double gunTurn = normalize(aimAngle - getGunHeading());

        setTurnGunRight(gunTurn);

        if (getGunHeat() == 0) {
            fire(firePower);
        }
    }

    private void dodgeBullets(ScannedBotEvent e) {

        double energyDrop = enemyEnergy - e.getEnergy();

        if (energyDrop > 0 && energyDrop <= 3) {
            moveDirection *= -1;
        }

        double turn =
                normalize(e.getBearing() + 90 - 25 * moveDirection);

        setTurnRight(turn);

        setForward(120 * moveDirection);
    }

    private void controlDistance(ScannedBotEvent e) {

        if (e.getDistance() < 150) {
            setBack(100);
        }

        if (e.getDistance() > 400) {
            setForward(100);
        }
    }

    private void lockRadar(ScannedBotEvent e) {

        double radarTurn =
                normalize(getHeading() + e.getBearing() - getRadarHeading());

        setTurnRadarRight(radarTurn * 2);
    }

    private double normalize(double angle) {

        while (angle > 180) angle -= 360;
        while (angle < -180) angle += 360;

        return angle;
    }

    private double distance(double x1, double y1, double x2, double y2) {

        double dx = x2 - x1;
        double dy = y2 - y1;

        return Math.sqrt(dx * dx + dy * dy);
    }

    @Override
    public void onHitWall(HitWallEvent e) {

        moveDirection *= -1;
        setForward(150 * moveDirection);
    }

    @Override
    public void onHitBot(HitBotEvent e) {

        fire(3);

        moveDirection *= -1;
        setBack(100);
    }
}
