package godtier;

import dev.robocode.tankroyale.botapi.*;
import dev.robocode.tankroyale.botapi.events.*;

public class GodTierTank extends Bot {

    private double enemyX;
    private double enemyY;
    private double enemyEnergy = 100;
    private int moveDirection = 1;

    static void main(String[] args) {
        new GodTierTank().start();
    }

    GodTierTank() {
        super(BotInfo.fromFile("GodTierTank.json"));
    }

    @Override
    public void run() {

        setAdjustGunForBodyTurn(true);
        setAdjustRadarForGunTurn(true);

        setRadarTurnRate(45);

        while (isRunning()) {

            if (getRadarTurnRemaining() == 0) {
                setTurnRadarLeft(360);
            }

            execute();
        }
    }

    @Override
    public void onScannedBot(ScannedBotEvent e) {

        double absBearing = getHeading() + e.getBearing();

        enemyX = getX() + Math.sin(Math.toRadians(absBearing)) * e.getDistance();
        enemyY = getY() + Math.cos(Math.toRadians(absBearing)) * e.getDistance();

        lockRadar(e);

        predictiveFire(e, absBearing);

        evasiveMovement(e);

        enemyEnergy = e.getEnergy();
    }

    private void predictiveFire(ScannedBotEvent e, double absBearing) {

        double firePower = Math.min(3, Math.max(1, 400 / e.getDistance()));

        double bulletSpeed = 20 - firePower * 3;

        double predictedX = enemyX;
        double predictedY = enemyY;

        double enemyHeading = e.getHeading();
        double enemyVelocity = e.getSpeed();

        int time = 0;

        while (++time * bulletSpeed <
                distance(getX(), getY(), predictedX, predictedY)) {

            predictedX += Math.sin(Math.toRadians(enemyHeading)) * enemyVelocity;
            predictedY += Math.cos(Math.toRadians(enemyHeading)) * enemyVelocity;
        }

        double aim =
                Math.toDegrees(Math.atan2(predictedX - getX(), predictedY - getY()));

        double gunTurn = normalizeBearing(aim - getGunHeading());

        setTurnGunLeft(gunTurn);

        if (getGunHeat() == 0) {
            fire(firePower);
        }
    }

    private void evasiveMovement(ScannedBotEvent e) {

        double energyDrop = enemyEnergy - e.getEnergy();

        if (energyDrop > 0 && energyDrop <= 3) {
            moveDirection *= -1;
        }

        double turn =
                normalizeBearing(e.getBearing() + 90 - 20 * moveDirection);

        setTurnLeft(turn);
        forward(120 * moveDirection);
    }

    private void lockRadar(ScannedBotEvent e) {

        double radarTurn =
                normalizeBearing(getHeading() + e.getBearing() - getRadarHeading());

        setTurnRadarLeft(radarTurn * 2);
    }

    private double normalizeBearing(double angle) {

        while (angle > 180) angle -= 360;
        while (angle < -180) angle += 360;

        return angle;
    }

    private double distance(double x1, double y1, double x2, double y2) {

        double dx = x2 - x1;
        double dy = y2 - y1;

        return Math.sqrt(dx * dx + dy * dy);
    }

    @Override
    public void onHitWall(HitWallEvent e) {

        moveDirection *= -1;
        forward(100 * moveDirection);
    }

    @Override
    public void onHitBot(HitBotEvent e) {

        if (e.isRammed()) {
            fire(3);
        }
    }
}
