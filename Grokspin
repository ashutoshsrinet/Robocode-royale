import dev.robocode.tankroyale.botapi.*;
import dev.robocode.tankroyale.botapi.events.*;
import java.util.*;

public class TotemBot extends Bot {

    private static class Enemy {
        double x, y, speed, direction, energy;
        int time;
    }

    private final Map<Integer, Enemy> enemies = new HashMap<>();
    private int spinDir = 1;  // +1 or -1 for spin direction

    public static void main(String[] args) {
        new TotemBot().start();
    }

    public TotemBot() {
        super(BotInfo.fromFile("bot.json"));
    }

    @Override
    public void run() {
        setTurnRadarRight(360); // initial sweep
        go();
    }

    @Override
    public void onScannedBot(ScannedBotEvent e) {
        int botId = e.getScannedBotId();
        Enemy en = enemies.computeIfAbsent(botId, k -> new Enemy());
        en.x = e.getX();
        en.y = e.getY();
        en.speed = e.getSpeed();
        en.direction = e.getDirection();
        en.energy = e.getEnergy();
        en.time = getTurnNumber();
    }

    @Override
    public void onTick(TickEvent tick) {
        // Cleanup stale enemies (not seen for 40 turns)
        enemies.values().removeIf(en -> getTurnNumber() - en.time > 40);

        if (enemies.isEmpty()) {
            setTurnRadarRight(360);
            setTurnRight(spinDir * 10000);
            go();
            return;
        }

        // === GOD-MODE SPIN MOVEMENT (core SpinBot principle) ===
        // Random occasional flip to break patterns
        if (getTurnNumber() % 150 == 0 || Math.random() < 0.008) {
            spinDir = -spinDir;
        }
        setTurnRight(spinDir * 10000); // infinite spin = pure evasion

        // === SPINNING RADAR (full melee scan every tick) ===
        setTurnRadarRight(360);

        // === PICK TARGET EACH TICK (lowest energy + closest threat) ===
        Enemy target = null;
        double bestScore = Double.MAX_VALUE;
        for (Enemy en : enemies.values()) {
            double dist = getDistanceTo(en.x, en.y);
            double score = en.energy * 0.6 + dist * 0.4; // favor low-energy + close
            if (score < bestScore) {
                bestScore = score;
                target = en;
            }
        }

        // === PERFECT CIRCULAR PREDICTIVE GUN ===
        if (target != null) {
            double power = Math.min(3.0, Math.max(0.1, getEnergy() / 10.0));
            double bulletSpeed = 20 - 3 * power;
            double dist = getDistanceTo(target.x, target.y);
            double ticks = dist / bulletSpeed;

            double ex = target.speed * Math.sin(Math.toRadians(target.direction));
            double ey = target.speed * Math.cos(Math.toRadians(target.direction));
            double predX = target.x + ex * ticks;
            double predY = target.y + ey * ticks;

            double gunBearing = calcAbsoluteBearing(predX, predY);
            double gunDelta = normalize(gunBearing - getGunDirection());
            setTurnGunRight(gunDelta);

            if (Math.abs(gunDelta) < 3 && getGunHeat() < 0.15) {
                fire(power);
            }
        }

        // Forward speed with distance control
        double distToTarget = target != null ? getDistanceTo(target.x, target.y) : 400;
        double speed = (distToTarget > 450) ? 8.0 : (distToTarget < 250 ? -6.0 : 5.0);
        setTargetSpeed(speed);

        // Wall avoidance via spin flip
        if (getX() < 80 || getX() > getArenaWidth() - 80 || getY() < 80 || getY() > getArenaHeight() - 80) {
            spinDir = -spinDir;
        }

        go();
    }

    @Override
    public void onHitByBullet(HitByBulletEvent e) {
        double bearing = calcBearing(e.getBullet().getDirection());
        setTurnRight(90 - bearing);       // perpendicular dodge
        spinDir = -spinDir;               // instant spin reversal = god dodge
        setTargetSpeed(-8);               // reverse thrust
        go();
    }

    @Override
    public void onHitWall(HitWallEvent e) {
        spinDir = -spinDir;               // bounce spin
    }

    // === HELPERS ===
    private double calcAbsoluteBearing(double tx, double ty) {
        return Math.toDegrees(Math.atan2(ty - getY(), tx - getX()));
    }

    private double calcBearing(double absBearing) {
        return normalize(absBearing - getDirection());
    }

    private double normalize(double angle) {
        while (angle > 180) angle -= 360;
        while (angle < -180) angle += 360;
        return angle;
    }

    private double getDistanceTo(double tx, double ty) {
        return Math.hypot(tx - getX(), ty - getY());
    }
}
